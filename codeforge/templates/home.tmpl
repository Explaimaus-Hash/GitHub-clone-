{{template "base/head" .}}
<main class="cf-home">
	<section class="cf-hero">
		<div class="cf-hero__inner">
			<span class="cf-badge cf-badge--lg cf-hero__eyebrow">
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>
				Self-hosted Git, reimagined
			</span>
			<h1 class="cf-hero__title">{{AppName}}</h1>
			<p class="cf-hero__lede">{{.i18n.Tr "app_desc"}}</p>
			<div class="cf-hero__cta">
				{{if .ShowRegistrationButton}}
					<a class="cf-btn cf-btn--primary cf-btn--lg" href="{{AppSubURL}}/user/sign_up">
						<svg class="cf-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
						{{.i18n.Tr "register"}}
					</a>
				{{end}}
				<a class="cf-btn cf-btn--secondary cf-btn--lg" href="{{AppSubURL}}/explore/repos">
					<svg class="cf-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
					{{.i18n.Tr "explore"}}
				</a>
			</div>
		</div>
		<div class="cf-hero__halo" aria-hidden="true"></div>
	</section>

	<section class="cf-features cf-main__container">
		<div class="cf-grid cf-grid--cols-3">
			<article class="cf-card cf-card--hoverable cf-feature">
				<div class="cf-card__body">
					<div class="cf-feature__icon" style="background:linear-gradient(135deg,rgba(207,188,255,.20),rgba(56,189,248,.20));">
						<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
					</div>
					<h3>Painless Git hosting</h3>
					<p class="cf-mute">Push, pull, clone, fork, and review code with the speed and ergonomics your team deserves.</p>
				</div>
			</article>
			<article class="cf-card cf-card--hoverable cf-feature">
				<div class="cf-card__body">
					<div class="cf-feature__icon" style="background:linear-gradient(135deg,rgba(231,195,101,.22),rgba(207,188,255,.20));">
						<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
					</div>
					<h3>Cross-platform</h3>
					<p class="cf-mute">Runs everywhere Go compiles &mdash; Windows, macOS, Linux, ARM. Pick the host you love.</p>
				</div>
			</article>
			<article class="cf-card cf-card--hoverable cf-feature">
				<div class="cf-card__body">
					<div class="cf-feature__icon" style="background:linear-gradient(135deg,rgba(56,189,248,.22),rgba(52,211,153,.20));">
						<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2 L3 7 v6 c0 5 4 9 9 9 s9-4 9-9 V7 z"/></svg>
					</div>
					<h3>Lightweight by design</h3>
					<p class="cf-mute">Low minimum requirements. Comfortably runs on a Raspberry Pi without breaking a sweat.</p>
				</div>
			</article>
			<article class="cf-card cf-card--hoverable cf-feature">
				<div class="cf-card__body">
					<div class="cf-feature__icon" style="background:linear-gradient(135deg,rgba(192,132,252,.22),rgba(207,188,255,.18));">
						<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
					</div>
					<h3>You own the data</h3>
					<p class="cf-mute">Self-hosted, self-controlled. No third-party telemetry, no surprise surveillance.</p>
				</div>
			</article>
			<article class="cf-card cf-card--hoverable cf-feature">
				<div class="cf-card__body">
					<div class="cf-feature__icon" style="background:linear-gradient(135deg,rgba(52,211,153,.22),rgba(231,195,101,.18));">
						<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
					</div>
					<h3>Issues, PRs, releases</h3>
					<p class="cf-mute">Everything you need for a healthy project lifecycle &mdash; right out of the box.</p>
				</div>
			</article>
			<article class="cf-card cf-card--hoverable cf-feature">
				<div class="cf-card__body">
					<div class="cf-feature__icon" style="background:linear-gradient(135deg,rgba(247,180,113,.22),rgba(192,132,252,.18));">
						<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
					</div>
					<h3>Open source</h3>
					<p class="cf-mute">Built in the open. Audit the code, ship patches, host with confidence.</p>
				</div>
			</article>
		</div>
	</section>
</main>
{{template "base/footer" .}}
