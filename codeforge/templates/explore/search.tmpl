{{/* CodeForge explore search */}}
<form class="cf-explore-search" role="search">
	<svg class="cf-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
	<input class="cf-input cf-explore-search__input" type="search" name="q" value="{{.Keyword}}" placeholder="{{.i18n.Tr "explore.search"}}..." autofocus>
	<button class="cf-btn cf-btn--primary" type="submit">{{.i18n.Tr "explore.search"}}</button>
</form>
