{{template "base/head" .}}
<main class="cf-settings user settings security two-factor">
	<div class="ui container">
		<div class="ui grid">
			{{template "user/settings/navbar" .}}
			<section class="cf-settings__content twelve wide column content">
				{{template "base/alert" .}}
				<h4 class="cf-settings__header ui top attached header">
					{{.i18n.Tr "settings.two_factor_enable_title"}}
				</h4>
				<div class="cf-settings__segment ui attached segment">
					<p class="cf-subtle">{{.i18n.Tr "settings.two_factor_scan_qr"}}</p>
					<img src="{{.QRCode}}" alt="{{.TwoFactorSecret}}">
					<p class="cf-subtle">{{.i18n.Tr "settings.two_factor_or_enter_secret"}} <b>{{.TwoFactorSecret}}</b></p>
					<form class="cf-form ui form" method="post">
						{{.CSRFTokenHTML}}
						<div class="required inline field">
							<span>{{.i18n.Tr "settings.two_factor_then_enter_passcode"}}</span>
							<input class="cf-input ui input" name="passcode" autocomplete="off" autofocus required>
						</div>
						<div class="cf-form__actions field">
							<button class="cf-btn cf-btn--primary ui green button">{{.i18n.Tr "settings.two_factor_verify"}}</button>
						</div>
					</form>
				</div>
			</section>
		</div>
	</div>
</main>
{{template "base/footer" .}}
