{{template "base/head" .}}
<main class="cf-settings user settings emails">
	<div class="ui container">
		<div class="ui grid">
			{{template "user/settings/navbar" .}}
			<section class="cf-settings__content twelve wide column content">
				{{template "base/alert" .}}
				<h4 class="cf-settings__header ui top attached header">
					{{.i18n.Tr "settings.manage_emails"}}
				</h4>
				<div class="cf-settings__segment ui attached segment">
					<div class="ui email list">
						<div class="item">
							<p class="cf-subtle">{{.i18n.Tr "settings.email_desc"}}</p>
						</div>
						{{range .Emails}}
							<div class="item ui grid">
								<div class="column">
									<strong>{{.Email}}</strong>
									{{if .IsPrimary}}<span class="ui green tiny primary label">{{$.i18n.Tr "settings.primary"}}</span>{{end}}
									{{if not .IsPrimary}}
										<div class="ui right">
											<button class="cf-btn cf-btn--danger ui red tiny basic button delete-button" data-url="{{$.Link}}/delete" data-id="{{.Email}}">
												{{$.i18n.Tr "settings.delete_email"}}
											</button>
										</div>
										{{if .IsActivated}}
											<div class="right floated">
												<form action="{{$.Link}}" method="post">
													{{$.CSRFTokenHTML}}
													<input name="_method" type="hidden" value="PRIMARY">
													<input name="email" type="hidden" value="{{.Email}}">
													<button class="cf-btn cf-btn--primary ui green tiny basic button">{{$.i18n.Tr "settings.primary_email"}}</button>
												</form>
											</div>
										{{end}}
									{{end}}
								</div>
							</div>
						{{end}}
					</div>
				</div>
				<div class="cf-settings__segment ui attached bottom segment">
					<form class="cf-form ui form" action="{{.Link}}" method="post">
						{{.CSRFTokenHTML}}
						<div class="required field {{if .Err_Email}}error{{end}}">
							<label for="email">{{.i18n.Tr "settings.add_new_email"}}</label>
							<input class="cf-input" id="email" name="email" type="email" autofocus required>
						</div>
						<div class="cf-form__actions field">
							<button class="cf-btn cf-btn--primary ui green button">
								{{.i18n.Tr "settings.add_email"}}
							</button>
						</div>
					</form>
				</div>
			</section>
		</div>
	</div>
</main>

<div class="ui small basic delete modal">
	<div class="ui icon header">
		<i class="trash icon"></i>
		{{.i18n.Tr "settings.email_deletion"}}
	</div>
	<div class="content">
		<p>{{.i18n.Tr "settings.email_deletion_desc"}}</p>
	</div>
	{{template "base/delete_modal_actions" .}}
</div>
{{template "base/footer" .}}
